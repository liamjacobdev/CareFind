{
  "name": "innetwork-frontend-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Unit + e2e tests for the InNetwork frontend logic (innetwork.logic.js) and page.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.js\" \"innetwork.logic.js\" \"innetwork.config.js\" \"build.mjs\" \"*.config.js\" \"tests-js/**/*.js\" \"tests-e2e/**/*.js\"",
    "typecheck": "tsc -p jsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "0.21.5",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
