# Copy to .env and edit. docker-compose.yml reads this file.

# Lock CORS to the origin your frontend is served from (no wildcard in prod).
# Comma-separate multiple origins. Leave empty only for local dev (localhost-only).
ALLOWED_ORIGINS=https://carefind.yourdomain.com

# Geocoding works out of the box via the free, keyless US Census Geocoder (US-only).
# Leave GEOCODE_USE_CENSUS=true (the default) and you need set nothing else here.
GEOCODE_USE_CENSUS=true

# CAREFIND_UA identifies you to NPPES and to the OPTIONAL OpenStreetMap Nominatim
# fallback. Nominatim rejects placeholder agents (HTTP 403), so set this to a real
# contact email ONLY if you want the fallback active (or if you disable Census).
CAREFIND_UA=CareFind/3.1 (+https://yourdomain.com; contact: you@yourdomain.com)

# Per-client rate limit on /api/* — requests per window / window seconds. 0 = off.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# Trust X-Forwarded-For for the real client IP. Enable ONLY behind a reverse proxy
# you control (the provided Caddy setup) — otherwise the limiter sees only the proxy
# IP and becomes one global bucket. docker-compose.yml already sets this to true.
CAREFIND_TRUST_PROXY=true

# Minimum seconds between live Nominatim calls (their policy: max 1 req/sec). Only
# affects the optional Nominatim fallback — the Census geocoder has no rate limit.
GEOCODE_MIN_INTERVAL=1.0

# Where commercial FHIR Plan-Net payers are configured (optional).
CAREFIND_PAYERS=payers.json

# SQLite path. In Docker this is set to /data/carefind.db (a persistent volume);
# override only if running outside the provided compose file.
# CAREFIND_DB=/data/carefind.db
