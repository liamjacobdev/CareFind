{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "innetwork*"
    }
  },
  "headers": [
    {
      "source": "/(innetwork\\.bundle\\.js|innetwork\\.theme\\.js|innetwork\\.logic\\.js|innetwork\\.config\\.js|innetwork-icon\\.svg|innetwork-og\\.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
