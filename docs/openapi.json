    "/api/providers/search": {
      "get": {
        "description": "One call: query NPPES, attach insurance flags (verified + estimated), then \u2014\nfor a radius search \u2014 geocode the candidate pool, keep only providers truly\nwithin `radius` miles of the ZIP center, sort by distance, and return ranked\nresults with coordinates already attached. The backend is authoritative for the\nradius boundary; the frontend plots the returned pins without re-geocoding.",
        "operationId": "providers_search_api_providers_search_get",
        "parameters": [
          {
            "in": "query",
            "name": "zip",
            "required": false,
            "schema": {
              "default": "",
              "title": "Zip",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "city",
            "required": false,
            "schema": {
              "default": "",
              "title": "City",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": false,
            "schema": {
              "default": "",
              "title": "State",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "npi",
            "required": false,
            "schema": {
              "default": "",
              "title": "Npi",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "name",
            "required": false,
            "schema": {
              "default": "",
              "title": "Name",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "taxonomy",
            "required": false,
            "schema": {
              "default": "",
              "title": "Taxonomy",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "default": "",
              "title": "Type",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 25,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "description": "Miles from the ZIP center to keep; 0 disables distance filtering",
            "in": "query",
            "name": "radius",
            "required": false,
            "schema": {
              "default": 0,
              "description": "Miles from the ZIP center to keep; 0 disables distance filtering",
              "title": "Radius",
              "type": "integer"
            }
          },
          {
            "description": "Comma-separated plan ids the provider must accept, e.g. 'medicare,aetna'",
            "in": "query",
            "name": "accepts",
            "required": false,
            "schema": {
              "default": "",
              "description": "Comma-separated plan ids the provider must accept, e.g. 'medicare,aetna'",
              "title": "Accepts",
              "type": "string"
            }
          },
          {
            "description": "'verified' = require confirmed acceptance; 'any' = also allow estimated matches",
            "in": "query",
            "name": "accepts_mode",
            "required": false,
            "schema": {
              "default": "verified",
              "description": "'verified' = require confirmed acceptance; 'any' = also allow estimated matches",
              "title": "Accepts Mode",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "geocode",
            "required": false,
            "schema": {
              "default": true,
              "title": "Geocode",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Providers Search Api Providers Search Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Providers Search"
      }
    },
