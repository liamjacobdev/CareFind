# Litestream — continuous SQLite backup to free object storage (E3).
# Copy to litestream.yml, fill in your bucket + credentials, then run:
#   litestream replicate -config litestream.yml
# Restore (disaster recovery):
#   litestream restore -config litestream.yml -o ./carefind.db replica
#
# Cloudflare R2 has a free tier with an S3-compatible API; AWS S3 / Backblaze B2 work too.
# CareFind's DB is fully re-ingestable from public sources, so this is for fast recovery,
# not irreplaceable data — but it makes a restore a single command.
dbs:
  - path: ./carefind.db            # must match CAREFIND_DB
    replicas:
      - name: replica
        type: s3
        bucket: your-bucket-name
        path: carefind/carefind.db
        endpoint: https://<accountid>.r2.cloudflarestorage.com   # R2 (or your S3 endpoint)
        region: auto
        # Credentials via env: LITESTREAM_ACCESS_KEY_ID / LITESTREAM_SECRET_ACCESS_KEY
        sync-interval: 10s
